    private function RegisterUnitNodeDrops takes nothing returns nothing
        local integer defId

        // Rewards: Copper Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n62J')
        call GNU_RegisterDrop(defId, "Main", 'I67E', 50, 100, 2, 6, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I67W', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I67Y', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I67X', 10, 100, 1, 1, true)

        // Rewards: Tin Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n62L')
        call GNU_RegisterDrop(defId, "Main", 'I67F', 50, 100, 2, 6, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I680', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I67Z', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I67Y', 10, 100, 1, 1, true)

        // Rewards: Silver Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n62M')
        call GNU_RegisterDrop(defId, "Main", 'I67G', 50, 100, 2, 6, true)

        // Rewards: Iron Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n62N')
        call GNU_RegisterDrop(defId, "Main", 'I67H', 50, 100, 2, 6, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I681', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I682', 10, 100, 1, 1, true)

        // Rewards: Gold Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n62O')
        call GNU_RegisterDrop(defId, "Main", 'I67I', 50, 100, 2, 6, true)

        // Rewards: Thorium Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n62K')
        call GNU_RegisterDrop(defId, "Main", 'I67L', 50, 100, 2, 6, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I687', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I686', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I685', 10, 100, 1, 1, true)
        call GNU_RegisterDrop(defId, "Secondary", 'I684', 10, 100, 1, 1, true)

        // Rewards: Gem Vein
        set defId = GNU_GetDefinitionIdByUnitCode('n02I')
        call GNU_RegisterDrop(defId, "Main", 'I684', 50, 100, 1, 2, true)
        call GNU_RegisterDrop(defId, "Main", 'I686', 50, 100, 1, 2, true)
        call GNU_RegisterDrop(defId, "Main", 'I685', 50, 100, 1, 2, true)
        call GNU_RegisterDrop(defId, "Main", 'I687', 50, 100, 1, 1, true)

        // Rewards: Mana Crystal
        set defId = GNU_GetDefinitionIdByUnitCode('n025')
        call GNU_RegisterDrop(defId, "Main", 'I00Y', 100, 100, 1, 2, true)

    endfunction

    private function RegisterSpawnGroups takes nothing returns nothing
        // Group 15: Any / Not configured Shared (Any / Not configured)

        // Group 1: Any Zone Units (Any Zone)
        call GNU_RegisterSpawnPoint(1, 1, GetRectCenterX(gg_rct_CrystalsAny0001), GetRectCenterY(gg_rct_CrystalsAny0001), 270.0, -1, 7)  // Any Crystal 0001
        call GNU_RegisterSpawnPoint(1, 1, GetRectCenterX(gg_rct_CrystalsAny0002), GetRectCenterY(gg_rct_CrystalsAny0002), 270.0, -1, 7)  // Any Crystal 0002
        call GNU_RegisterSpawnPoint(1, 1, GetRectCenterX(gg_rct_CrystalsAny0003), GetRectCenterY(gg_rct_CrystalsAny0003), 270.0, -1, 7)  // Any Crystal 0003
        call GNU_RegisterSpawnPoint(1, 1, GetRectCenterX(gg_rct_CrystalsAny0004), GetRectCenterY(gg_rct_CrystalsAny0004), 270.0, -1, 7)  // Any Crystal 0004
        call GNU_RegisterSpawnPoint(1, 1, GetRectCenterX(gg_rct_CrystalsAny0005), GetRectCenterY(gg_rct_CrystalsAny0005), 270.0, -1, 7)  // Any Crystal 0005
        call GNU_RegisterSpawnPoint(1, 1, GetRectCenterX(gg_rct_CrystalsAny0006), GetRectCenterY(gg_rct_CrystalsAny0006), 270.0, -1, 7)  // Any Crystal 0006

