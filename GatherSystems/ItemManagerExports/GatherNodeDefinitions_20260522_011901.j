    //===========================================================================
    // RANDOM IN ZONE
    // Random zone placements use ZonesCore zone rects at runtime.
    // No extra gather-zone rect registration is exported here.
    //===========================================================================
    private function RegisterSpawnRegions takes nothing returns nothing
        // Intentionally empty.
    endfunction

    //===========================================================================
    // INITIALIZATION
    //===========================================================================
    private function DelayedSpawn takes nothing returns nothing
        // Spawn initial nodes after definitions and rect-backed registrations are in place
        call GNI_SpawnInitialAll()
        call GNU_SpawnInitialAll()

        if GN_IsDebugMode() then
            call BJDebugMsg("|cff00ff00[GatherNodeDefinitions]|r All nodes spawned")
        endif
    endfunction

    private function DelayedInit takes nothing returns nothing
        // Register all definitions
        call RegisterItemNodes()
        call RegisterUnitNodes()
        call RegisterUnitNodeDrops()
        call RegisterSpawnRegions()
        call RegisterSpawnGroups()

        set GND_SpawnTrigger = CreateTrigger()
        call TriggerRegisterTimerEvent(GND_SpawnTrigger, 0.10, false)
        call TriggerAddAction(GND_SpawnTrigger, function DelayedSpawn)

        if GN_IsDebugMode() then
            call BJDebugMsg("|cff00ff00[GatherNodeDefinitions]|r All nodes registered")
        endif
    endfunction

    private function Init takes nothing returns nothing
        set GND_InitTrigger = CreateTrigger()
        call TriggerRegisterTimerEvent(GND_InitTrigger, 0.00, false)
        call TriggerAddAction(GND_InitTrigger, function DelayedInit)
    endfunction

endlibrary
