        Set VariableSet Pet_Dead = False
        Set VariableSet Shadowclaw = Shadowclaw 0835 <gen>
        Unit Group - Add Shadowclaw to TamedUnits
        Unit Group - Add Shadowclaw to CompanionFocusNazgrek
