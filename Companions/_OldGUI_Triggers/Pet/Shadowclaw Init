        Set VariableSet Shadowclaw_hp = (Shadowclaw_hp_base + (Integer(((Max life of Nazgrek) x 0.75))))
        Unit - Set Max HP of Shadowclaw to Shadowclaw_hp
        -------- Set armor --------
        Set VariableSet Shadowclaw_armor = (Shadowclaw_armor_base + ((Armor of Nazgrek) x 0.80))
        Unit - Set Armor of Shadowclaw to Shadowclaw_armor
        -------- Set dmg --------
        Set VariableSet Shadowclaw_dmg = (Shadowclaw_dmg_base + (Integer(((Real((Base Damage of Nazgrek for weapon index 0))) x 0.75))))
        Unit - Set Base Damage of Shadowclaw to Shadowclaw_dmg for weapon index: 0
